# API keys — add at least one to enable AI features
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Django (auto-generated by install script if not set)
DJANGO_SECRET_KEY=change-me-in-production

# General
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Agent defaults
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_TEMPERATURE=0.2
