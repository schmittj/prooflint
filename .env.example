# API keys
# Current pre-MVP AI review uses OPENAI_API_KEY.
OPENAI_API_KEY=
# Stored for planned provider integrations; not used by the bot yet.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Django (auto-generated by install script if not set)
# Leave blank or keep the placeholder; the launcher replaces it with a real secret.
DJANGO_SECRET_KEY=change-me-in-production
# Internal write-token for localhost-only settings/shutdown endpoints.
# The launcher fills this automatically if it is blank.
PROOFLINT_ADMIN_TOKEN=

# General
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Agent defaults
DEFAULT_MODEL=gpt-5.4-mini
DEFAULT_REASONING_EFFORT=low
